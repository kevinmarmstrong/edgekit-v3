# EdgeKit research/eval environment
#
# Copy to .env.research.local if you want a shell-loadable profile for deeper runs.
# The default suite does not require secrets. Real provider/cloud/MCP checks are opt-in.

# local | live
EDGEKIT_SUITE_TARGET=local

# Useful for tuning loops. Omit or set to 0 for the full prompt matrix.
EDGEKIT_SUITE_PROMPT_LIMIT=0
EDGEKIT_SUITE_SEED=20260525

# Set to 0 to watch the browser during evals.
EDGEKIT_SUITE_HEADLESS=1

# Default local preview URLs.
EDGEKIT_SUITE_SITE_URL=http://127.0.0.1:4174/edgekit
EDGEKIT_SUITE_ECOMMERCE_URL=http://127.0.0.1:4173

# Provider matrix controls. With downloadPolicy=never, Chrome/WebLLM routes must
# resolve or degrade through EdgeKit fallback without downloading models.
EDGEKIT_SUITE_PROVIDER_MODES=chrome,webllm,cascade
EDGEKIT_SUITE_DOWNLOAD_POLICY=never

# Optional strict real-provider mode for machines configured with browser models.
# Set this only when Chrome AI/Nano or WebLLM should be treated as required.
EDGEKIT_REQUIRE_REAL_PROVIDERS=0

# Optional future integration hooks. Keep secrets server-side; these should point
# to app-owned test routes, not raw provider or broad MCP credentials.
# EDGEKIT_SUITE_CLOUD_ROUTE_URL=https://example.test/api/edgekit/cloud-route
# EDGEKIT_SUITE_AG_UI_ENDPOINT=https://example.test/api/ag-ui
# EDGEKIT_SUITE_MCP_PROXY_URL=https://example.test/api/mcp
