{
  "name": "@kevinmarmstrong/edgekit-knowledge",
  "version": "0.3.2",
  "type": "module",
  "description": "Knowledge sources, tools, skills, and Markdown memory for Edgekit.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinmarmstrong/edgekit.git",
    "directory": "packages/knowledge"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kevinmarmstrong/edgekit": "workspace:^",
    "@kevinmarmstrong/edgekit-skills": "workspace:^",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  }
}
