{
  "name": "@kevinmarmstrong/edgekit-react",
  "version": "0.1.0",
  "type": "module",
  "description": "React primitives for edgekit browser-native agents.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/kevinmarmstrong/edgekit.git",
    "directory": "packages/react"
  },
  "keywords": [
    "edgekit",
    "react",
    "browser-ai",
    "agent-ui",
    "generative-ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kevinmarmstrong/edgekit": "workspace:^",
    "@kevinmarmstrong/edgekit-ui": "workspace:^"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "react": "^19.2.1"
  }
}
