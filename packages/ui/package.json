{
  "name": "@kevinmarmstrong/edgekit-ui",
  "version": "0.3.1",
  "type": "module",
  "description": "Web component UI for edgekit browser-native agents.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "sideEffects": [
    "./dist/index.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kevinmarmstrong/edgekit.git",
    "directory": "packages/ui"
  },
  "keywords": [
    "edgekit",
    "web-component",
    "browser-ai",
    "agent-ui",
    "generative-ui"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@kevinmarmstrong/edgekit": "workspace:^",
    "@kevinmarmstrong/edgekit-governance": "workspace:^",
    "@kevinmarmstrong/edgekit-skills": "workspace:^",
    "lit": "^3.3.3"
  }
}
